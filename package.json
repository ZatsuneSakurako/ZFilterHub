{
  "name": "zfilterhub",
  "packageManager": "yarn@4.13.0",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./src/ZFilterHub.js",
  "exports": {
    ".": {
      "import": "./src/ZFilterHub.js",
